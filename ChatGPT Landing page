<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Diamond Street Car Club</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #0b0b0b;
      color: white;
      line-height: 1.6;
    }

    /* HERO */
    .hero {
      height: 100vh;
      background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.9)),
                  url('https://images.unsplash.com/photo-1503376780353-7e6692767b70') center/cover no-repeat;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 20px;
    }

    .hero h1 {
      font-size: 3rem;
      letter-spacing: 2px;
    }

    .hero p {
      margin-top: 10px;
      font-size: 1.2rem;
      color: #ccc;
    }

    .btn {
      margin-top: 20px;
      padding: 12px 25px;
      background: #d4af37;
      color: black;
      border: none;
      font-weight: bold;
      cursor: pointer;
      text-decoration: none;
    }

    /* SECTION */
    .section {
      padding: 60px 20px;
      max-width: 1000px;
      margin: auto;
      text-align: center;
    }

    .section h2 {
      margin-bottom: 15px;
      font-size: 2rem;
      color: #d4af37;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }

    .card {
      background: #1a1a1a;
      padding: 20px;
      border-radius: 10px;
    }

    /* FOOTER */
    footer {
      text-align: center;
      padding: 20px;
      background: #000;
      color: #777;
      font-size: 0.9rem;
    }
  </style>
</head>

<body>

  <!-- HERO -->
  <div class="hero">
    <h1>DIAMOND STREET CAR CLUB</h1>
    <p>Built for the streets. Driven by passion.</p>
    <a class="btn" href="#join">Join The Club</a>
  </div>

  <!-- ABOUT -->
  <div class="section">
    <h2>About Us</h2>
    <p>
      Diamond Street Car Club is a community of car enthusiasts who live for builds, cruises,
      meets, and the culture behind the machines. From classics to modern builds — we represent it all.
    </p>
  </div>

  <!-- FEATURES -->
  <div class="section">
    <h2>What We Do</h2>

    <div class="cards">
      <div class="card">
        <h3>Car Meets</h3>
        <p>Weekly and monthly meetups for members and guests.</p>
      </div>

      <div class="card">
        <h3>Build Showcase</h3>
        <p>Show off your ride and get featured on our page.</p>
      </div>

      <div class="card">
        <h3>Street Culture</h3>
        <p>We represent real automotive lifestyle and community.</p>
      </div>
    </div>
  </div>

  <!-- JOIN -->
  <div class="section" id="join">
    <h2>Join The Club</h2>
    <p>Follow us or reach out to become part of Diamond Street.</p>
    <br />
    <a class="btn" href="mailto:diamondstreetcarclub@email.com">Contact Us</a>
  </div>

  <!-- FOOTER -->
  <footer>
    © 2026 Diamond Street Car Club — All Rights Reserved
  </footer>

</body>
</html>
